# Clerk authentication — copy to .env.local and fill in from the Clerk dashboard
# (https://dashboard.clerk.com → your app → "API keys"). .env.local is gitignored.

# Publishable key (safe for the browser). Starts with pk_test_ or pk_live_.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Secret key (server-only — never expose). Starts with sk_test_ or sk_live_.
# Used by the eve channel to verify the user's session token.
CLERK_SECRET_KEY=sk_test_xxx

# Optional but recommended in production: comma-separated list of origins allowed
# to mint tokens for this app (Clerk "azp" check). Include your prod + local URLs.
# CLERK_AUTHORIZED_PARTIES=https://mtg-agent-sand.vercel.app,http://localhost:3000
